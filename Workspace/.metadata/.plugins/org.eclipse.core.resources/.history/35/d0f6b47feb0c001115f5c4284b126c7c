package oopsconcept;

public class Car {
	int wheel;			// instance variable. 
	String color;
	float price;			// property 
	
	Car() {
		System.out.println("object created..");
		this.wheel=4;
		this.color="Unkown";
		this.price=800000;
	}
	void start() {
		System.out.println("Car Start");
	}
	void stop() {
		System.out.println("Car Stop");
	}
	
	void setCarDetails(int wheel, String color, float price) {
		this.wheel= wheel;
		this.color= color;
		this.price = price;
	}
	void displayCarInfo(String msg) {
		String info=msg;		// local variable 
		System.out.println("Car Details "+info);
		//System.out.println(info);
		System.out.println("Wheel "+wheel);
		System.out.println("Color "+color);
		System.out.println("Price "+price);
	}
	
}
